# --- Jhonattan IA (Jia) ---
# Copia este archivo a .env y completa los valores. NUNCA subas .env al repo.

# Clave de la API de Claude (Anthropic). https://console.anthropic.com/
ANTHROPIC_API_KEY=

# (Opcional) Sobrescribir modelos por defecto.
# IA_MODEL_REASONING=claude-opus-4-8
# IA_MODEL_CHEAP=claude-haiku-4-5-20251001

# Bot de Telegram (consola de control). Token de @BotFather.
TELEGRAM_IA_BOT_TOKEN=

# Tu chat_id de Telegram (unico autorizado). Lo da @userinfobot.
TELEGRAM_JHONATTAN_CHAT_ID=

# (Opcional) Cuantos dias hacia atras descarga el cron cada 6h (ventana movil).
# Por defecto 2. Normalize es idempotente, asi que solapar dias es seguro.
BEE_LOOKBACK_DAYS=2

# (Opcional) Expresion cron de la descarga. Por defecto cada 6 horas.
BEE_CRON=0 */6 * * *

# --- Control de gastos del API (notificacion por ntfy) ---
# Servidor ntfy privado (Fibex) con token, o ntfy.sh publico (sin token).
# El topic debe empezar con "fibex-" si usas el token write-only de Fibex.
NTFY_SERVER=https://ntfy.thomas-talk.me
NTFY_TOPIC=fibex-jia-99
# Token Bearer (write-only). Dejar vacio si usas ntfy.sh publico.
NTFY_TOKEN=

# (Opcional) cron del reporte de gastos. Por defecto cada 6 horas.
COSTOS_CRON=0 */6 * * *
# (Opcional) presupuesto diario en USD. Si se supera, la notificacion va con alerta.
COSTOS_PRESUPUESTO_DIARIO_USD=5
